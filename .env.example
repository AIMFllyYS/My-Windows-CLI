DEEPSEEK_API_KEY=your_api_key_here

# ZhiPu GLM API Key (required for GLM models and web search)
ZHIPU_API_KEY=your_api_key_here

# Custom OpenAI-compatible provider (optional, overrides chat API requests)
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=your_custom_api_key_here
AI_MODEL=your_model_name_here
