{
  "name": "coding-cli",
  "version": "0.6.3",
  "description": "Coding quick command tool - project paths, GitHub status, CLI auto commands",
  "main": "src/index.ts",
  "bin": {
    "coding": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"const fs=require('fs'); if(fs.existsSync('dist')) fs.rmSync('dist',{recursive:true})\"",
    "rebuild": "npm run clean && npm run build",
    "link": "npm link",
    "pkg": "pkg dist/index.js --targets node18-win-x64 --output dist/coding.exe"
  },
  "keywords": ["cli", "coding", "github", "kiro", "claude"],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "pkg": "^5.8.1",
    "typescript": "^5.3.2"
  }
}
